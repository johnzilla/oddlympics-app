# Required in production. In dev, if RESEND_API_KEY is unset, magic links print to the console
# instead of being emailed.
RESEND_API_KEY=
EMAIL_FROM="oddlympics <hello@oddlympics.app>"

# HMAC secret for signing magic-link tokens. Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MAGIC_LINK_SECRET=

# Public base URL used in magic links. Defaults to http://localhost:4321 in dev.
PUBLIC_SITE_URL=https://oddlympics.app

# SQLite database file path. Defaults to ./data/oddlympics.db.
DATABASE_PATH=./data/oddlympics.db
