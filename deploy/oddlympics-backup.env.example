# /etc/oddlympics-backup.env
# chmod 640 /etc/oddlympics-backup.env && chown root:oddlympics /etc/oddlympics-backup.env
#
# Loaded by oddlympics-backup.service via EnvironmentFile=. Kept off git.
# Separate from /etc/oddlympics.env so the app process cannot read the B2 key.

# Backblaze B2 application key SCOPED to a single bucket.
# Create at: B2 console -> App Keys -> Add a New Application Key.
B2_ACCOUNT_ID=replace_me_keyID
B2_APPLICATION_KEY=replace_me_applicationKey
B2_BUCKET=oddlympics-backups

# rclone remote name (used in the destination URL: <remote>:<bucket>/path).
# Default 'b2' matches the script defaults; only change if you have multiple
# rclone remotes and want a different name.
RCLONE_REMOTE=b2

# Optional: override DB path if non-default.
# DATABASE_PATH=/var/lib/oddlympics/oddlympics.db
