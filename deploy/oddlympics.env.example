# /etc/oddlympics.env
# chmod 640 /etc/oddlympics.env && chown root:oddlympics /etc/oddlympics.env
#
# This file is loaded by systemd via EnvironmentFile= in oddlympics.service.
# Values here OVERRIDE process Environment= directives in the unit file.
# Keep this file off git; copy from oddlympics.env.example and fill in.

RESEND_API_KEY=re_replace_me
EMAIL_FROM="oddlympics <hello@oddlympics.app>"

# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MAGIC_LINK_SECRET=replace_me

PUBLIC_SITE_URL=https://oddlympics.app
DATABASE_PATH=/var/lib/oddlympics/oddlympics.db

# football-data.org API key for the World Cup schedule ingestor (Phase 2).
# Free tier, 10 req/min. Get one at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=replace_me

# Phase 3 — kickoff notifications safety switch. Defaults to false (dry-run).
# Flip to "true" to actually send. The systemd timer runs every 5 min either
# way; the script just logs what it would do until this is true.
KICKOFF_NOTIFICATIONS_ENABLED=false
