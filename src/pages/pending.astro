---
import Layout from '../components/Layout.astro';
import { TEAMS } from '../lib/teams';
export const prerender = true;

// Build a slug→label map and serialize for the browser. ~2KB embed at build
// time so the inline ?rc= reader can resolve ?team= without a network call.
const TEAM_LABEL_JSON = JSON.stringify(
  Object.fromEntries(TEAMS.map((t) => [t.slug, t.label]))
);
---
<Layout title="Check your email — oddlympics" noindex analytics>
  <main class="hero">
    <div class="hero-content">
      <span id="banner" class="banner"></span>
      <h1 id="headline" class="headline"></h1>
      <p class="subhead">
        <span id="lead"></span><span id="to-email"></span>.
        <span id="trail"></span>
      </p>
      <script is:inline>
        try {
          const params = new URL(location.href).searchParams;
          const action = params.get('action');
          const email = params.get('email');
          const COPY = action === 'manage'
            ? {
                banner: 'Schedule link sent',
                headline: 'Check your email.',
                lead: 'We just sent a link to your schedule',
                trail: 'Click it to pick or change the teams you follow.',
              }
            : {
                banner: 'Step 2 of 2',
                headline: 'Check your email.',
                lead: 'We just sent a confirmation link',
                trail: 'Click it to lock in your spot.',
              };
          document.getElementById('banner').textContent = COPY.banner;
          document.getElementById('headline').textContent = COPY.headline;
          document.getElementById('lead').textContent = COPY.lead;
          document.getElementById('trail').textContent = COPY.trail;
          if (email && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            document.getElementById('to-email').textContent = ' to ' + email;
          }
        } catch {}
      </script>
      <p class="subhead" style="margin-top:24px">
        No email? Check spam, or <a href="/" class="link">try again</a>.
      </p>

      <section id="share-card" class="share-card" hidden>
        <h2 id="share-heading" class="share-heading">Share with a friend</h2>
        <p class="share-blurb" id="share-blurb"></p>
        <div class="share-row">
          <input
            id="share-url"
            class="share-url"
            type="text"
            readonly
            value=""
            aria-label="Your referral link"
          />
          <button id="share-btn" class="share-btn" type="button">Share</button>
        </div>
      </section>

      <script is:inline define:vars={{ TEAM_LABEL_JSON }}>
        try {
          const params = new URL(location.href).searchParams;
          const rc = params.get('rc');
          const teamSlug = params.get('team');
          // Defensive gate: only allow the locked 8-char [a-z0-9] shape (D-03 + T-14-11).
          if (!rc || !/^[a-z0-9]{8}$/.test(rc)) {
            // share card stays hidden
          } else {
            const shareUrl = location.origin + '/r/' + rc;
            const labels = JSON.parse(TEAM_LABEL_JSON);
            const teamLabel = teamSlug && labels[teamSlug] ? labels[teamSlug] : '';
            const shareTextStr = "I'm following " + (teamLabel || 'my team') +
              " — get your team's World Cup kickoff alerts.\n" + shareUrl;

            // DOM-API value assignment only (never setAttribute, never HTML
            // string injection — T-14-13).
            const urlInput = document.getElementById('share-url');
            urlInput.value = shareUrl;

            // textContent assignment only (never HTML-string injection).
            const blurbEl = document.getElementById('share-blurb');
            blurbEl.textContent = teamLabel
              ? ('Know someone else following ' + teamLabel + '? Share your link while you wait for the email.')
              : 'Share your link while you wait for the email.';

            // Heading stays generic "Share with a friend" per D-15 / CONTEXT Discretion.

            const card = document.getElementById('share-card');
            card.hidden = false;

            function copyFallback() {
              try {
                navigator.clipboard.writeText(shareTextStr + '\n' + shareUrl).then(function () {
                  const b = document.getElementById('share-btn');
                  const prev = b.textContent;
                  b.textContent = 'Copied!';
                  setTimeout(function () { b.textContent = prev; }, 1500);
                }).catch(function () {});
              } catch (e) {}
            }

            const btn = document.getElementById('share-btn');
            btn.addEventListener('click', function () {
              try {
                if (typeof navigator !== 'undefined' && typeof navigator.share === 'function') {
                  navigator.share({ text: shareTextStr, url: shareUrl }).catch(function (e) {
                    // AbortError = user dismissed the share sheet; do not fall through (T-14-17).
                    if (e && e.name === 'AbortError') return;
                    copyFallback();
                  });
                } else {
                  copyFallback();
                }
              } catch (e) {
                copyFallback();
              }
            });
          }
        } catch {}
      </script>
    </div>
  </main>
</Layout>

<style>
  .hero { min-height: 100dvh; display: flex; align-items: center; padding: var(--pad); }
  .hero-content { max-width: 720px; }
  .share-card { margin-top: 40px; padding: 20px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; max-width: 460px; }
  .share-heading { margin: 0 0 8px; font-size: 16px; font-weight: 700; color: var(--fg); }
  .share-blurb { margin: 0 0 14px; font-size: 14px; color: var(--fg-dim); line-height: 1.5; }
  .share-row { display: flex; gap: 8px; align-items: stretch; flex-wrap: wrap; }
  .share-url { flex: 1; min-width: 0; padding: 10px 12px; font-family: var(--font-mono); font-size: 13px; color: var(--fg); background: var(--bg); border: 1px solid var(--line); border-radius: 6px; }
  .share-url:focus { outline: none; border-color: var(--accent); }
  .share-btn { padding: 10px 18px; font-family: var(--font-sans); font-size: 14px; font-weight: 700; letter-spacing: 0.02em; color: var(--accent-ink); background: var(--accent); border: 0; border-radius: 6px; cursor: pointer; white-space: nowrap; }
  .share-btn:hover { filter: brightness(1.08); }
  @media (max-width: 520px) {
    :root { --pad: 28px; }
    .share-row { flex-direction: column; }
    .share-btn { width: 100%; }
  }
</style>
