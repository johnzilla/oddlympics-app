---
import Layout from '../components/Layout.astro';
export const prerender = true;
---
<Layout title="Confirmed — oddlympics" noindex analytics>
  <main class="hero">
    <div class="hero-content">
      <span id="banner" class="banner"></span>
      <h1 id="headline" class="headline"></h1>
      <p id="sub" class="subhead"></p>
      <p id="cta-row" class="subhead" style="margin-top:24px" hidden>
        <a href="/" class="link">Re-send confirmation →</a>
      </p>
      <p class="subhead" style="margin-top:24px">
        <a href="/" class="link">← back to oddlympics</a>
      </p>

      <section id="share-card" class="share-card" hidden>
        <h2 class="share-heading">Share with a friend</h2>
        <p class="share-blurb" id="share-blurb"></p>
        <div class="share-row">
          <input
            id="share-url"
            class="share-url"
            type="text"
            readonly
            value=""
            aria-label="Your referral link"
          />
          <button id="share-btn" class="share-btn" type="button">Share</button>
        </div>
      </section>

      <section id="vote-card" class="vote-card" hidden>
        <h2 class="vote-heading">One more thing — what should we cover next?</h2>
        <p class="vote-blurb">After the World Cup, oddlympics is going to do this for the sports nobody else covers properly. Which one do you want?</p>
        <div class="vote-grid" id="vote-grid">
          <button class="vote-opt" type="button" data-sport="curling">Curling</button>
          <button class="vote-opt" type="button" data-sport="esports">Esports</button>
          <button class="vote-opt" type="button" data-sport="battlebots">BattleBots</button>
          <button class="vote-opt" type="button" data-sport="speedcubing">Speedcubing</button>
          <button class="vote-opt" type="button" data-sport="excel">Excel World Championship</button>
          <button class="vote-opt" type="button" data-sport="drone-racing">Drone racing</button>
          <button class="vote-opt" type="button" data-sport="other" id="vote-other-btn">Something else…</button>
        </div>
        <div class="vote-other-row" id="vote-other-row" hidden>
          <input id="vote-other-text" class="vote-other-input" type="text" maxlength="200" placeholder="Which sport?" aria-label="Which sport should we cover?" />
          <button id="vote-other-send" class="vote-send" type="button">Send</button>
        </div>
        <p class="vote-done" id="vote-done" hidden>Noted — thanks. We'll let you know what wins.</p>
      </section>
    </div>
  </main>

  <script is:inline>
    try {
      const COPY = {
        ok: {
          banner: "You're in",
          headline: "Confirmed. We'll see you at kickoff.",
          sub: "We'll email you the moment oddlympics goes live — well before World Cup 2026 kicks off in June. No spam between now and then.",
          cta: false,
        },
        already: {
          banner: 'Already confirmed',
          headline: "You're already on the list.",
          sub: "Nothing more to do. We'll email you when it's live.",
          cta: false,
        },
        'bad-token': {
          banner: 'Link expired',
          headline: "That link didn't work.",
          sub: 'Magic links expire after 24 hours. Sign up again and click the new link.',
          cta: true,
        },
        unknown: {
          banner: "Couldn't find that signup",
          headline: "Hmm — we don't have a record of that email.",
          sub: 'Sign up again and click the link in the new email.',
          cta: true,
        },
      };
      const status = new URL(location.href).searchParams.get('status') || 'ok';
      const c = COPY[status] || COPY.ok;
      document.getElementById('banner').textContent = c.banner;
      document.getElementById('headline').textContent = c.headline;
      document.getElementById('sub').textContent = c.sub;
      if (c.cta) {
        document.getElementById('cta-row').hidden = false;
      }
      document.title = c.headline + ' — oddlympics';
    } catch {}
  </script>

  <script is:inline>
    try {
      const params = new URL(location.href).searchParams;
      const status = params.get('status') || 'ok';
      // D-16 / D-02: only show share card on success-equivalent statuses.
      // Bad / unknown branches skip — no rc to share, no recruit pitch to a stranger.
      if (status !== 'ok' && status !== 'already') {
        // share card stays hidden
      } else {
        const rc = params.get('rc');
        // Defensive 8-char [a-z0-9] gate against ?rc= injection (T-14-11).
        if (!rc || !/^[a-z0-9]{8}$/.test(rc)) {
          // share card stays hidden
        } else {
          const shareUrl = location.origin + '/r/' + rc;
          // D-16: generic copy on /confirmed — no team personalization.
          // The confirm 303 does not carry &team=, so teamLabel is hardcoded ''.
          const teamLabel = '';
          const shareTextStr = "I'm following " + (teamLabel || 'my team') +
            " — get your team's World Cup kickoff alerts.\n" + shareUrl;

          // DOM-property assignment only (T-14-13).
          const urlInput = document.getElementById('share-url');
          urlInput.value = shareUrl;

          // textContent only (never HTML-string injection).
          document.getElementById('share-blurb').textContent =
            'Help someone else not miss kickoff.';

          document.getElementById('share-card').hidden = false;

          function copyFallback() {
            try {
              navigator.clipboard.writeText(shareTextStr + '\n' + shareUrl).then(function () {
                const b = document.getElementById('share-btn');
                const prev = b.textContent;
                b.textContent = 'Copied!';
                setTimeout(function () { b.textContent = prev; }, 1500);
              }).catch(function () {});
            } catch (e) {}
          }

          const btn = document.getElementById('share-btn');
          btn.addEventListener('click', function () {
            try {
              if (typeof navigator !== 'undefined' && typeof navigator.share === 'function') {
                navigator.share({ text: shareTextStr, url: shareUrl }).catch(function (e) {
                  // AbortError = user dismissed the share sheet; do not fall through (T-14-17).
                  if (e && e.name === 'AbortError') return;
                  copyFallback();
                });
              } else {
                copyFallback();
              }
            } catch (e) {
              copyFallback();
            }
          });
        }
      }
    } catch {}
  </script>

  <script is:inline>
    // "What's next" vote capture — the lead-gen bridge. Posts to /api/vote, which
    // records into feature_requests (attributed via the ?rc= already in this URL).
    // Entirely try-wrapped: any failure leaves the confirm page fully intact.
    try {
      var vparams = new URL(location.href).searchParams;
      var vstatus = vparams.get('status') || 'ok';
      if (vstatus === 'ok' || vstatus === 'already') {
        var rcRaw = vparams.get('rc') || '';
        var rc = /^[a-z0-9]{8}$/.test(rcRaw) ? rcRaw : '';

        var card = document.getElementById('vote-card');
        var grid = document.getElementById('vote-grid');
        var done = document.getElementById('vote-done');
        var otherRow = document.getElementById('vote-other-row');
        var otherText = document.getElementById('vote-other-text');
        var otherSend = document.getElementById('vote-other-send');
        var submitted = false;

        function finish() {
          submitted = true;
          if (grid) grid.hidden = true;
          if (otherRow) otherRow.hidden = true;
          if (done) done.hidden = false;
        }

        function send(sport, text) {
          if (submitted) return;
          var body = new URLSearchParams();
          body.set('sport', sport);
          if (rc) body.set('rc', rc);
          if (text) body.set('text', text);
          try {
            fetch('/api/vote', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: body.toString()
            }).catch(function () {});
          } catch (e) {}
          // Optimistic: a vote is low-stakes — show thanks immediately, don't
          // make the user wait on the round-trip or punish a flaky network.
          finish();
        }

        if (card) card.hidden = false;

        var opts = document.querySelectorAll('.vote-opt');
        for (var i = 0; i < opts.length; i++) {
          opts[i].addEventListener('click', function (ev) {
            var sport = ev.currentTarget.getAttribute('data-sport');
            if (sport === 'other') {
              if (grid) grid.hidden = true;
              if (otherRow) otherRow.hidden = false;
              if (otherText) otherText.focus();
            } else {
              send(sport, '');
            }
          });
        }

        if (otherSend) {
          otherSend.addEventListener('click', function () {
            var t = ((otherText && otherText.value) || '').trim();
            if (!t) { if (otherText) otherText.focus(); return; }
            send('other', t);
          });
        }
        if (otherText) {
          otherText.addEventListener('keydown', function (ev) {
            if (ev.key === 'Enter') { ev.preventDefault(); if (otherSend) otherSend.click(); }
          });
        }
      }
    } catch (e) {}
  </script>
</Layout>

<style>
  .hero { min-height: 100dvh; display: flex; align-items: center; padding: var(--pad); }
  .hero-content { max-width: 720px; }
  .share-card { margin-top: 40px; padding: 20px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; max-width: 460px; }
  .share-heading { margin: 0 0 8px; font-size: 16px; font-weight: 700; color: var(--fg); }
  .share-blurb { margin: 0 0 14px; font-size: 14px; color: var(--fg-dim); line-height: 1.5; }
  .share-row { display: flex; gap: 8px; align-items: stretch; flex-wrap: wrap; }
  .share-url { flex: 1; min-width: 0; padding: 10px 12px; font-family: var(--font-mono); font-size: 13px; color: var(--fg); background: var(--bg); border: 1px solid var(--line); border-radius: 6px; }
  .share-url:focus { outline: none; border-color: var(--accent); }
  .share-btn { padding: 10px 18px; font-family: var(--font-sans); font-size: 14px; font-weight: 700; letter-spacing: 0.02em; color: var(--accent-ink); background: var(--accent); border: 0; border-radius: 6px; cursor: pointer; white-space: nowrap; }
  .share-btn:hover { filter: brightness(1.08); }

  .vote-card { margin-top: 28px; padding: 20px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; max-width: 460px; }
  .vote-heading { margin: 0 0 8px; font-size: 16px; font-weight: 700; color: var(--fg); }
  .vote-blurb { margin: 0 0 14px; font-size: 14px; color: var(--fg-dim); line-height: 1.5; }
  .vote-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .vote-opt { padding: 8px 14px; font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--fg); background: var(--bg); border: 1px solid var(--line-strong); border-radius: 999px; cursor: pointer; }
  .vote-opt:hover { border-color: var(--accent); color: var(--accent); }
  .vote-opt:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(184, 53, 13, 0.15); }
  .vote-other-row { display: flex; gap: 8px; margin-top: 12px; }
  .vote-other-input { flex: 1; min-width: 0; padding: 10px 12px; font-family: var(--font-sans); font-size: 14px; color: var(--fg); background: var(--bg); border: 1px solid var(--line-strong); border-radius: 6px; }
  .vote-other-input:focus { outline: none; border-color: var(--accent); }
  .vote-send { padding: 10px 18px; font-family: var(--font-sans); font-size: 14px; font-weight: 700; color: var(--accent-ink); background: var(--accent); border: 0; border-radius: 6px; cursor: pointer; white-space: nowrap; }
  .vote-send:hover { filter: brightness(1.08); }
  .vote-done { margin: 4px 0 0; font-size: 14px; font-weight: 600; color: var(--accent); }

  @media (max-width: 520px) {
    :root { --pad: 28px; }
    .share-row { flex-direction: column; }
    .share-btn { width: 100%; }
    .vote-other-row { flex-direction: column; }
    .vote-send { width: 100%; }
  }
</style>
