---
import Layout from '../components/Layout.astro';
export const prerender = true;
---
<Layout title="Confirmed — oddlympics" noindex analytics>
  <main class="hero">
    <div class="hero-content">
      <span id="banner" class="banner"></span>
      <h1 id="headline" class="headline"></h1>
      <p id="sub" class="subhead"></p>
      <p id="cta-row" class="subhead" style="margin-top:24px" hidden>
        <a href="/" class="link">Re-send confirmation →</a>
      </p>
      <p class="subhead" style="margin-top:24px">
        <a href="/" class="link">← back to oddlympics</a>
      </p>
    </div>
  </main>

  <script is:inline>
    try {
      const COPY = {
        ok: {
          banner: "You're in",
          headline: "Confirmed. We'll see you at kickoff.",
          sub: "We'll email you the moment oddlympics goes live — well before World Cup 2026 kicks off in June. No spam between now and then.",
          cta: false,
        },
        already: {
          banner: 'Already confirmed',
          headline: "You're already on the list.",
          sub: "Nothing more to do. We'll email you when it's live.",
          cta: false,
        },
        'bad-token': {
          banner: 'Link expired',
          headline: "That link didn't work.",
          sub: 'Magic links expire after 24 hours. Sign up again and click the new link.',
          cta: true,
        },
        unknown: {
          banner: "Couldn't find that signup",
          headline: "Hmm — we don't have a record of that email.",
          sub: 'Sign up again and click the link in the new email.',
          cta: true,
        },
      };
      const status = new URL(location.href).searchParams.get('status') || 'ok';
      const c = COPY[status] || COPY.ok;
      document.getElementById('banner').textContent = c.banner;
      document.getElementById('headline').textContent = c.headline;
      document.getElementById('sub').textContent = c.sub;
      if (c.cta) {
        document.getElementById('cta-row').hidden = false;
      }
      document.title = c.headline + ' — oddlympics';
    } catch {}
  </script>
</Layout>

<style>
  .hero { min-height: 100dvh; display: flex; align-items: center; padding: var(--pad); }
  .hero-content { max-width: 720px; }
  @media (max-width: 520px) { :root { --pad: 28px; } }
</style>
