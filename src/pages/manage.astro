---
export const prerender = false;

import { verifyToken } from '../lib/token';
import { buildSessionCookie, readSessionFromCookie } from '../lib/session';
import { db, getByEmail, type VipSignup, type Match } from '../lib/db';
import { TEAMS } from '../lib/teams';

const CONFEDERATION_ORDER = [
  'UEFA',
  'CONMEBOL',
  'CONCACAF',
  'CAF',
  'AFC',
  'OFC',
] as const;

const CONFEDERATION_LABEL: Record<(typeof CONFEDERATION_ORDER)[number], string> = {
  UEFA: 'UEFA — Europe',
  CONMEBOL: 'CONMEBOL — South America',
  CONCACAF: 'CONCACAF — North & Central America',
  CAF: 'CAF — Africa',
  AFC: 'AFC — Asia',
  OFC: 'OFC — Oceania',
};

const groupedTeams = CONFEDERATION_ORDER.map((conf) => ({
  conf,
  label: CONFEDERATION_LABEL[conf],
  teams: TEAMS.filter((t) => t.confederation === conf),
}));

const url = Astro.url;
const urlToken = url.searchParams.get('token') ?? '';
const status = url.searchParams.get('status') ?? '';

// Auth: prefer URL token (manage flow on first arrival); fall back to session cookie.
// On URL-token success, mint a 30-day session cookie so subsequent visits skip the email step.
let result = urlToken ? verifyToken(urlToken, 'manage') : null;
if (result) {
  Astro.response.headers.set('Set-Cookie', buildSessionCookie(result.email));
}
if (!result) {
  result = readSessionFromCookie(Astro.request.headers.get('cookie'));
}

const valid = result !== null;
const hadUrlToken = urlToken.length > 0;

let user: VipSignup | undefined;
let matches: (Match & { home_tla?: string | null; away_tla?: string | null })[] = [];
let selectedIds: number[] = [];

if (valid && result) {
  user = getByEmail.get(result.email) as VipSignup | undefined;

  if (user?.team) {
    // Resolve the slug → numeric team id for the matches JOIN query
    const teamRow = db.prepare('SELECT id FROM teams WHERE slug = ?').get(user.team) as { id: number } | undefined;
    if (teamRow) {
      selectedIds = [teamRow.id];
      matches = db.prepare<[number, number]>(`
        SELECT
          m.id, m.utc_date, m.stage, m.group_name,
          m.home_team_id, m.away_team_id, m.status,
          h.tla AS home_tla, a.tla AS away_tla
        FROM matches m
        LEFT JOIN teams h ON h.id = m.home_team_id
        LEFT JOIN teams a ON a.id = m.away_team_id
        WHERE m.home_team_id = ? OR m.away_team_id = ?
        ORDER BY m.utc_date ASC
      `).all(teamRow.id, teamRow.id) as (Match & { home_tla?: string | null; away_tla?: string | null })[];
    }
  }
}

// Phase 9 — MANAGE-01: STATUS_COPY for /manage?status=... redirects from /api/save-selection.
const STATUS_COPY: Record<string, { kind: 'ok' | 'err'; text: string }> = {
  saved:       { kind: 'ok',  text: 'Saved. Your schedule is updated below.' },
  'bad-token': { kind: 'err', text: 'That link is no longer valid. Request a new one.' },
  'bad-tz':    { kind: 'err', text: "Couldn't read your time zone. Try again." },
  'bad-team':  { kind: 'err', text: 'Team not recognized. Use the dropdown.' },
  unknown:     { kind: 'err', text: "We couldn't find your signup. Sign up at /." },
  server:      { kind: 'err', text: 'Server hiccup. Try again in a minute.' },
};

const statusMsg = status ? STATUS_COPY[status] ?? null : null;

// RESEARCH Risk 3: a session-valid unsubscribed user would see the editor but get
// ?status=unknown on save (setSelection's WHERE excludes unsubscribed rows).
// Show a "you've unsubscribed" message instead of the editor form.
const isUnsubscribed = valid && user?.unsubscribed_at != null;

const title = valid && !isUnsubscribed
  ? 'Your schedule — oddlympics'
  : 'Manage your schedule — oddlympics';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-wRAab3seDWDDBnGbRbe0K.js"></script>
  <script is:inline>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>
</head>
<body>
  <main class="hero">
    <div class="hero-content">

      {/* A: Signed-out branch — no session, no URL token */}
      {!valid && !hadUrlToken && (
        <>
          <span class="banner">Already signed up</span>
          <h1 class="headline">Manage your schedule.</h1>
          <p class="subhead">
            Drop your email and we'll send you a link to pick or change the World Cup teams you follow.
          </p>

          <form class="cta-form" method="post" action="/api/manage">
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              aria-label="Email address"
            />
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              class="hp"
              aria-hidden="true"
            />
            <button type="submit">Send me the link</button>
          </form>

          <p id="error" class="error" role="alert" hidden></p>

          <p class="subhead" style="margin-top:24px">
            Not on the list yet? <a href="/" class="link">Sign up here</a>.
          </p>

          <script is:inline>
            try {
              const COPY = {
                'bad-email': 'That email looks off — try again.',
                'bad-form': 'Something went wrong with the form. Try again.',
                'bad-origin': 'Submission blocked. Please use the form on this page.',
                'rate-limited': 'Too many tries. Wait an hour and try again.',
                email: "We couldn't send the email. Try again in a minute.",
                server: 'Server hiccup. Try again in a minute.',
              };
              const code = new URL(location.href).searchParams.get('error');
              if (code) {
                const el = document.getElementById('error');
                el.textContent = COPY[code] || 'Something went wrong.';
                el.hidden = false;
              }
            } catch {}
          </script>
        </>
      )}

      {/* B: Expired/invalid URL token */}
      {!valid && hadUrlToken && (
        <>
          <span class="banner">Link expired</span>
          <h1 class="headline">That link didn't work.</h1>
          <p class="subhead">Magic links expire after 24 hours.</p>
          <a href="/manage" class="link">Request a new one</a>
        </>
      )}

      {/* C: Unsubscribed defensive branch (RESEARCH Risk 3) */}
      {valid && isUnsubscribed && (
        <>
          <span class="banner">Unsubscribed</span>
          <h1 class="headline">You've unsubscribed.</h1>
          <p class="subhead"><a href="/" class="link">Sign up again</a> to start getting alerts.</p>
          <p class="subhead" style="margin-top:32px">
            <a href="/" class="link">← oddlympics.app</a>
          </p>
        </>
      )}

      {/* D: Signed-in editor branch */}
      {valid && !isUnsubscribed && (
        <>
          <span class="banner">{!user?.team ? 'Pick a team' : 'Your schedule'}</span>
          <h1 class="headline">Pick the teams you follow.</h1>
          <p class="subhead">
            {!user?.team
              ? "You're signed up. Choose a team below to start getting kickoff alerts."
              : "We'll email you about an hour before each match they play, in your local time. Change anytime — your sign-in lasts 30 days on this device."}
          </p>

          {statusMsg && (
            <p class={`flash ${statusMsg.kind}`} role="status">{statusMsg.text}</p>
          )}

          <form method="post" action="/api/save-selection" class="picker-form">
            {hadUrlToken && (
              <input type="hidden" name="token" value={urlToken} />
            )}

            <div class="tz-row">
              <span class="tz-prefix">Notifications in:</span>
              <strong id="tz-display">{user?.timezone || 'UTC'}</strong>
              <button type="button" id="tz-change" class="link-button" hidden>change</button>
              <select
                id="tz-select"
                name="timezone"
                data-saved-tz={user?.timezone ?? ''}
                hidden
              >
                <option value={user?.timezone || 'UTC'} selected>{user?.timezone || 'UTC'}</option>
              </select>
              <noscript>
                <span class="tz-noscript">(JavaScript disabled — timezone defaults to {user?.timezone || 'UTC'}; enable JS to change)</span>
              </noscript>
            </div>

            <fieldset class="picker">
              <legend class="legend">YOUR TEAM</legend>
              <select name="team" aria-label="Your team" required>
                <option value="" disabled selected={!user?.team}>Pick your team</option>
                {groupedTeams.map(({ label, teams }) => (
                  <optgroup label={label}>
                    {teams.map((t) => (
                      <option value={t.slug} selected={t.slug === user?.team}>{t.label}</option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </fieldset>

            <button type="submit">Save selection</button>
          </form>

          {selectedIds.length > 0 && (
            <section class="schedule">
              <h2 class="section-h">Your matches ({matches.length})</h2>
              {matches.length === 0 ? (
                <p class="subhead">No matches yet. Once the schedule is loaded for your picks, they'll show up here.</p>
              ) : (
                <ol class="match-list" id="match-list">
                  {matches.map((m) => (
                    <li class="match" data-utc={m.utc_date}>
                      <span class="match-time" data-utc={m.utc_date}>
                        {new Date(m.utc_date * 1000).toISOString()}
                      </span>
                      <span class="match-stage">{m.group_name ?? m.stage.replace(/_/g, ' ')}</span>
                      <span class="match-teams">
                        {m.home_tla ?? 'TBD'} <span class="dim">vs</span> {m.away_tla ?? 'TBD'}
                      </span>
                    </li>
                  ))}
                </ol>
              )}
            </section>
          )}

          <p class="subhead" style="margin-top:32px">
            <a href="/" class="link">← oddlympics.app</a>
            {valid && (
              <>
                {' · '}
                <form method="post" action="/api/logout" style="display:inline">
                  <button type="submit" class="link-button">Log out</button>
                </form>
              </>
            )}
          </p>
        </>
      )}

    </div>
  </main>

  {valid && !isUnsubscribed && (
    <>
      <script is:inline>
        // TZ auto-detect + manual override for the /manage editor.
        // Ported verbatim from schedule.astro (pre-09-03).
        function setupTz() {
          const display = document.getElementById('tz-display');
          const changeBtn = document.getElementById('tz-change');
          const tzSelect = document.getElementById('tz-select');
          if (!display || !changeBtn || !tzSelect) return;

          // Populate <select> with all IANA zones from the browser.
          const saved = tzSelect.dataset.savedTz || '';
          let detected = '';
          try { detected = Intl.DateTimeFormat().resolvedOptions().timeZone; } catch {}
          const preferred = saved || detected || 'UTC';

          const zones = (() => {
            try { return Intl.supportedValuesOf('timeZone'); } catch { return [preferred]; }
          })();

          tzSelect.innerHTML = '';
          for (const z of zones) {
            const opt = document.createElement('option');
            opt.value = z;
            opt.textContent = z;
            if (z === preferred) opt.selected = true;
            tzSelect.appendChild(opt);
          }

          // Show the detected / saved TZ in the strong element.
          display.textContent = preferred;

          // Reveal the change button.
          changeBtn.hidden = false;

          changeBtn.addEventListener('click', () => {
            tzSelect.hidden = false;
            changeBtn.hidden = true;
          });

          tzSelect.addEventListener('change', () => {
            display.textContent = tzSelect.value;
          });
        }
        setupTz();
      </script>

      <script is:inline>
        // Render match times in the user's local timezone using Intl.DateTimeFormat.
        // Each <li class="match"> has data-utc (Unix epoch seconds).
        // The <span class="match-time"> is pre-populated with an ISO string as fallback.
        (function () {
          const items = document.querySelectorAll('#match-list .match-time[data-utc]');
          if (!items.length) return;
          let tz = '';
          try { tz = Intl.DateTimeFormat().resolvedOptions().timeZone; } catch {}
          const saved = document.getElementById('tz-select')?.dataset.savedTz;
          if (saved) tz = saved;
          const fmt = new Intl.DateTimeFormat('en-US', {
            weekday: 'short', month: 'short', day: 'numeric',
            hour: 'numeric', minute: '2-digit',
            timeZone: tz || undefined,
            timeZoneName: 'short',
          });
          items.forEach((el) => {
            const utc = Number(el.dataset.utc);
            if (!utc) return;
            try { el.textContent = fmt.format(new Date(utc * 1000)); } catch {}
          });
        })();
      </script>
    </>
  )}
</body>
</html>

<style is:global>
  :root {
    --bg: #0b0b0e;
    --fg: #ececf1;
    --fg-dim: #b8b8c2;
    --line: rgba(255, 255, 255, 0.18);
    --surface: rgba(255, 255, 255, 0.06);
    --accent: hsl(18 70% 56%);
    --accent-ink: #0b0b0e;
    --ok: hsl(140 50% 60%);
    --err: hsl(360 70% 65%);
    --pad: 48px;
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; background: var(--bg); color: var(--fg); font-family: var(--mono); -webkit-font-smoothing: antialiased; }
  body { min-height: 100dvh; }
  .hero { min-height: 100dvh; display: flex; align-items: center; padding: var(--pad); }
  .hero-content { max-width: 920px; }
  .banner { display: inline-block; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700; color: var(--accent); border: 1px solid var(--accent); padding: 5px 10px; border-radius: 999px; margin-bottom: 18px; }
  .headline { font-size: 36px; font-weight: 700; line-height: 1.1; letter-spacing: -0.01em; margin: 0 0 14px; }
  .subhead { font-size: 14px; line-height: 1.55; color: var(--fg-dim); margin: 0 0 28px; max-width: 540px; }
  .link { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .flash { font-size: 13px; line-height: 1.5; padding: 10px 14px; border-radius: 6px; margin: 0 0 20px; border: 1px solid; }
  .flash.ok { color: var(--ok); border-color: var(--ok); }
  .flash.err { color: var(--err); border-color: var(--err); }
  .picker-form { display: flex; flex-direction: column; gap: 16px; max-width: 460px; }
  .tz-row { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--fg-dim); flex-wrap: wrap; }
  .tz-prefix { white-space: nowrap; }
  .tz-row strong { color: var(--fg); }
  .tz-noscript { font-size: 12px; color: var(--fg-dim); }
  #tz-select { background: var(--surface); border: 1px solid var(--line); color: var(--fg); font-family: var(--mono); font-size: 13px; padding: 4px 8px; border-radius: 4px; }
  #tz-select:focus { outline: none; border-color: var(--accent); }
  .picker { border: 1px solid var(--line); border-radius: 8px; padding: 16px; background: var(--surface); }
  .legend { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-dim); margin-bottom: 12px; display: block; }
  .picker select { width: 100%; background: var(--surface); border: 1px solid var(--line); color: var(--fg); font-family: var(--mono); font-size: 14px; padding: 10px 12px; border-radius: 6px; }
  .picker select:focus { outline: none; border-color: var(--accent); }
  button[type="submit"] { padding: 12px 18px; font-family: var(--mono); font-size: 14px; font-weight: 700; letter-spacing: 0.02em; color: var(--accent-ink); background: var(--accent); border: 0; border-radius: 6px; cursor: pointer; width: 100%; max-width: 460px; }
  button[type="submit"]:hover { filter: brightness(1.08); }
  .schedule { margin-top: 32px; }
  .section-h { font-size: 18px; font-weight: 700; line-height: 1.2; margin: 0 0 16px; }
  .match-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .match { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; align-items: center; padding: 12px 14px; background: var(--surface); border: 1px solid var(--line); border-radius: 6px; font-size: 13px; }
  .match-time { color: var(--fg); }
  .match-stage { font-size: 11px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-dim); }
  .match-teams { font-size: 14px; font-weight: 700; text-align: right; }
  .match-teams .dim { font-weight: 400; color: var(--fg-dim); }
  .link-button { background: none; border: none; padding: 0; font-family: var(--mono); font-size: 14px; color: var(--accent); cursor: pointer; text-decoration: underline; text-underline-offset: 3px; }
  .cta-form { display: flex; gap: 8px; max-width: 460px; }
  .cta-form input[type="email"] { flex: 1; min-width: 0; padding: 12px 14px; font-family: var(--mono); font-size: 14px; color: var(--fg); background: var(--surface); border: 1px solid var(--line); border-radius: 6px; }
  .cta-form input[type="email"]:focus { outline: none; border-color: var(--accent); }
  .cta-form input[type="email"]::placeholder { color: var(--fg-dim); }
  .cta-form button { width: auto; padding: 12px 18px; font-family: var(--mono); font-size: 14px; font-weight: 700; letter-spacing: 0.02em; color: var(--accent-ink); background: var(--accent); border: 0; border-radius: 6px; cursor: pointer; white-space: nowrap; }
  .cta-form button:hover { filter: brightness(1.08); }
  .error { margin: 12px 0 0; color: var(--accent); font-size: 13px; line-height: 1.5; }
  .hp { position: absolute; left: -10000px; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  @media (max-width: 640px) {
    :root { --pad: 24px; }
    .headline { font-size: 28px; }
    .match { grid-template-columns: 1fr; gap: 4px; }
    .cta-form { flex-direction: column; }
    .cta-form button { width: 100%; }
  }
</style>
