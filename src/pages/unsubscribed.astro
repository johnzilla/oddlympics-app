---
import Layout from '../components/Layout.astro';
export const prerender = true;
---
<Layout title="Unsubscribed — oddlympics" noindex analytics>
  <main class="hero">
    <div class="hero-content">
      <span id="banner" class="banner"></span>
      <h1 id="headline" class="headline"></h1>
      <p id="sub" class="subhead"></p>
      <p class="subhead" style="margin-top:24px">
        <a href="/" class="link">← back to oddlympics</a>
      </p>
    </div>
  </main>

  <script is:inline>
    try {
      const COPY = {
        ok: {
          banner: 'Unsubscribed',
          headline: "You're off the list.",
          sub: "We won't email you again. If this was a mistake, sign up at oddlympics.app to opt back in.",
        },
        already: {
          banner: 'Already unsubscribed',
          headline: "You're already off the list.",
          sub: "Nothing more to do. We won't email you.",
        },
        'bad-token': {
          banner: 'Link expired',
          headline: "That unsubscribe link didn't work.",
          sub: 'The link may have expired or been mistyped. If you keep getting emails you do not want, reply to one of them and we will remove you manually.',
        },
        unknown: {
          banner: "Couldn't find that signup",
          headline: "We don't have a record of that email.",
          sub: 'You may already be unsubscribed, or never signed up.',
        },
      };
      const status = new URL(location.href).searchParams.get('status') || 'ok';
      const c = COPY[status] || COPY.ok;
      document.getElementById('banner').textContent = c.banner;
      document.getElementById('headline').textContent = c.headline;
      document.getElementById('sub').textContent = c.sub;
      document.title = c.headline + ' — oddlympics';
    } catch {}
  </script>
</Layout>

<style>
  .hero { min-height: 100dvh; display: flex; align-items: center; padding: var(--pad); }
  .hero-content { max-width: 720px; }
  @media (max-width: 520px) { :root { --pad: 28px; } }
</style>
